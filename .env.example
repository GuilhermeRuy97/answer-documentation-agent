# ============================================================
# .env.example - Copy to .env and fill in your values
# Never commit .env to git
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Voyage AI (MongoDB-managed) ---
# Get from: https://www.mongodb.com/docs/voyageai/management/api-keys/
VOYAGE_API_KEY=pa-...

# --- Supabase ---
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Use the service_role key, NOT the anon key

# --- Firecrawl ---
# Get from: https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-...

# --- LangSmith (Evaluation & Tracing) ---
# Get from: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=anthropic-rag-agent

# --- Models ---
GENERATION_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-opus-4-7
EMBEDDING_MODEL=voyage-4
RERANK_MODEL=rerank-2

# --- Ingestion Settings ---
DOCS_URL=https://platform.claude.com/docs/en/build-with-claude
CRAWL_LIMIT=80            # Max pages to crawl
CRAWL_MAX_RETRIES=2       # Per-page scrape retries
# CRAWL_INCLUDE_PATTERNS: comma-separated URL substrings to keep (empty = all).
CRAWL_INCLUDE_PATTERNS=
CRAWL_EXCLUDE_PATTERNS=sitemap.xml,/api/,changelog
CHUNK_SIZE=1200           # Characters per chunk
CHUNK_OVERLAP=200         # Overlap between chunks

# --- Retrieval Settings ---
RETRIEVAL_TOP_K=6
RERANK_TOP_K=6
RECALL_THRESHOLD=0.30     # Cosine prefilter floor (vector-only path)
RELEVANCE_THRESHOLD=0.45  # Agent retry gate (mean rerank score)
MAX_RETRY_COUNT=2
USE_HYBRID_SEARCH=true    # Requires scripts/migrate_hybrid_search.sql
RRF_K=60                  # Reciprocal Rank Fusion dampening constant

# --- Memory / Sessions ---
SESSION_TTL_SECONDS=3600       # Idle eviction for the in-memory cache
MAX_HISTORY_MESSAGES=12        # Above this, older turns are summarized
PERSIST_SESSIONS=true          # Store chat history in Supabase

# --- Security ---
# API_KEYS: comma-separated keys; empty = auth disabled (dev)
API_KEYS=
CORS_ORIGINS=*                 # Comma-separated origins; * = allow all (dev)
RATE_LIMIT_ASK=20/minute       # slowapi rate limit for POST /ask

# --- App Settings ---
APP_PORT=8000
LOG_LEVEL=INFO
